{
  "name": "ecommerce-ts-backend",
  "version": "0.0.0",
  "description": "ecommerce-backend",
  "type": "commonjs",
  "devDependencies": {
    "@types/ali-oss": "^6.16.11",
    "@types/axios": "^0.14.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^8.2.0",
    "@types/exceljs": "^1.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "~29.5",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mime-types": "^2.1.4",
    "@types/mongoose": "^5.11.97",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "~20.0.0",
    "@types/xlsx": "^0.0.36",
    "@typescript-eslint/eslint-plugin": "~6.15",
    "@typescript-eslint/parser": "~6.15",
    "eslint": "~8.56",
    "eslint-config-prettier": "~9.1",
    "eslint-plugin-jest": "~27.6",
    "husky": "^9.1.4",
    "jest": "~29.7",
    "lint-staged": "^15.2.7",
    "nodemon": "^3.1.0",
    "pre-commit": "^1.2.2",
    "prettier": "~3.1.0",
    "rimraf": "~5.0.0",
    "ts-api-utils": "~1.0",
    "ts-jest": "~29.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.3"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node --files src/index.ts",
    "clean": "rimraf coverage dist tmp",
    "prebuild": "npm run lint",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:release": "npm run clean && tsc -p tsconfig.release.json",
    "lint": "eslint . --ext .ts --ext .mts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "ts.check": "tsc --project tsconfig.json",
    "add-build": "git add dist",
    "seed": "npx ts-node src/utils/seed.ts",
    "deploy": "npm run build && npx vercel --prod",
    "lint-staged": "lint-staged",
    "prettier": "prettier --config .prettierrc --write .",
    "vercel:deploy": "npm run build && npx vercel --prod",
    "prepare": "husky"
  },
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "ali-oss": "^6.20.0",
    "aws-sdk": "^2.1579.0",
    "axios": "^1.6.7",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^2.1.35",
    "moment-timezone": "^0.5.45",
    "mongoose": "^8.2.1",
    "mongoose-slug-updater": "^3.3.0",
    "morgan": "^1.10.0",
    "multer": "1.4.5-lts.1",
    "tslib": "~2.6",
    "xlsx": "^0.18.5"
  },
  "lint-staged": {
    "**/*.{ts,md,json}": [
      "prettier --write"
    ]
  },
  "pre-commit": [
    "ts.check",
    "build",
    "add-build"
  ],
  "packageManager": "pnpm@9.8.0+sha512.8e4c3550fb500e808dbc30bb0ce4dd1eb614e30b1c55245f211591ec2cdf9c611cabd34e1364b42f564bd54b3945ed0f49d61d1bbf2ec9bd74b866fcdc723276"
}

{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "removeComments": true,
    "sourceMap": false,
    "inlineSources": false,
    "declaration": false,
    "noEmitOnError": false,
    "strict": false,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*", "src/types/*"]
    },
    "types": ["express"],
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["./src/**/*"]
}
